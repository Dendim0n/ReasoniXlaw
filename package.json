{
  "name": "@dendim0n/reasonixlaw",
  "version": "0.1.1",
  "description": "Prefix-cache stable context engine for DeepSeek-compatible models — OpenClaw plugin",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "deepseek",
    "context-engine",
    "prefix-cache"
  ],
  "license": "MIT",
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.5.0"
    },
    "build": {
      "openclawVersion": "2026.5.27",
      "pluginSdkVersion": "2026.5.27"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": ">=2026.5.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  }
}
